{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "responseOverrides": {
    "404": { "rewrite": "/404.html" }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".webmanifest": "application/manifest+json"
  }
}
