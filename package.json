{
  "name": "maskinporten-kit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Maskinporten Tools — a TypeScript client, a credential-free local mock, and a scope wizard for Norway's Maskinporten.",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "license": "MIT",
  "author": "Maxim Salnikov (@webmaxru)",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "wizard": "pnpm --filter maskinporten-wizard build && pnpm --filter maskinporten-wizard start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0"
  }
}
