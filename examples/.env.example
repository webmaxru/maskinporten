# Copy to `.env` and fill in. NEVER commit real values (private keys are secrets).
#
# IMPORTANT: none of these are needed for local development against
# `maskinporten-mock`. They are only required to talk to the REAL Maskinporten.
# See docs/prerequisites.md for how to obtain each value.

# "test" | "prod"
MASKINPORTEN_ENV=test

# The client_id you get after registering a Maskinporten client in Samarbeidsportalen.
MASKINPORTEN_CLIENT_ID=

# Your signing key as a PEM string (or a JWK JSON string). KEEP SECRET.
MASKINPORTEN_PRIVATE_KEY=

# The key id (kid) registered for your JWK. Must be globally unique.
MASKINPORTEN_KID=

# The scope(s) your client has been granted, space-separated.
MASKINPORTEN_SCOPE=skatteetaten:formueinntekt/skattemelding
